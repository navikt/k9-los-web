	"scripts": {
		"test": "jest --colors",
		"dev": "node webpack/webpack.dev.server.mjs --config webpack/webpack.dev.mjs",
		"build": "cross-env NODE_ENV=production SENTRY_RELEASE=$(git rev-parse --short HEAD) webpack --config webpack/webpack.prod.mjs",
		"ts-check": "tsc",
		"lint": "eslint --cache --fix \"src/**/*.ts?(x)\"",
		"up": "docker-compose up -d --remove-orphans --build",
		"down": "docker-compose down",
		"sentry-release": "node ./setup/sentry-release.cjs",
		"prepare": "husky install"
	},
	"msw": {
		"workerDirectory": "src/client"
	},
	"lint-staged": {
		"src/client/**/*.ts?(x)": "eslint --fix",
		"src/client/**/*.{ts,tsx,js,jsx,css}": "prettier --write"
	},
