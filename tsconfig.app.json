{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "ES2023",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"types": ["vite/client", "jest"],
		"allowArbitraryExtensions": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": false,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"paths": {
			"app/*": ["./src/client/app/app/*"],
			"api/*": ["./src/client/app/api/*"],
			"form/*": ["./src/client/app/form/*"],
			"hooks/*": ["./src/client/app/hooks/*"],
			"kodeverk/*": ["./src/client/app/kodeverk/*"],
			"navAnsatt/*": ["./src/client/app/navAnsatt/*"],
			"sharedComponents/*": ["./src/client/app/sharedComponents/*"],
			"avdelingsleder/*": ["./src/client/app/avdelingsleder/*"],
			"saksbehandler/*": ["./src/client/app/saksbehandler/*"],
			"filter/*": ["./src/client/app/filter/*"],
			"types/*": ["./src/client/app/types/*"],
			"utils/*": ["./src/client/app/utils/*"]
		}
	},
	"include": ["src", "setup/setup-test-env.ts", "globals.d.ts"]
}
